# Instalacja

INSTALL_DIR=/opt/gobbla
API_DIR=/opt/gobbla/gobbla-api
UI_DIR=/opt/gobbla/gobbla-ui
DEPLOY_DIR=/opt/gobbla/deploy
DEPLOY_COMPOSE_FILE=/opt/gobbla/deploy/compose.yml

# Repozytoria

API_BRANCH=master
UI_BRANCH=master

# Domena

DOMAIN=uk-gobbla.duckdns.org
EMAIL=gobbla.api@gmail.com

# Docker

MONGO_VERSION=8

#ssh

SSH_USER=arnolds

# GitHub

API_REPO=git@github.com:ArnoldSteinhager/gobbla-api.git
UI_REPO=git@github.com:ArnoldSteinhager/gobbla-ui.git

ENVIRONMENT=production
SERVER_LAN_IP=192.168.33.252