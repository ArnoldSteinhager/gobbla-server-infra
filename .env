# Instalacja

INSTALL_DIR=/opt/gobbla

# Repozytoria

API_BRANCH=master
UI_BRANCH=master

# Domena

DOMAIN=uk-gobbla.duckdns.org
EMAIL=gobbla.api@gmail.com

# Docker

MONGO_VERSION=8

#ssh

